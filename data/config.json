{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": true,
        "category": "linux-kernel"
      },
      {
        "name": "BBC Politics",
        "url": "https://feeds.bbci.co.uk/news/politics/rss.xml",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "NYTimes Politics",
        "url": "https://rss.nytimes.com/services/xml/rss/nyt/Politics.xml",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "WSJ World News",
        "url": "https://feeds.a.dj.com/rss/RSSWorldNews.xml",
        "enabled": true,
        "category": "politics"
      },
      {
        "name": "TechCrunch",
        "url": "https://techcrunch.com/feed/",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "Ars Technica",
        "url": "https://feeds.arstechnica.com/arstechnica/index",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "NYTimes Technology",
        "url": "https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "Bloomberg Markets",
        "url": "https://feeds.bloomberg.com/markets/news.rss",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "WSJ Markets",
        "url": "https://feeds.a.dj.com/rss/RSSMarketsMain.xml",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "CNBC Finance",
        "url": "https://www.cnbc.com/id/10000664/device/rss/rss.html",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "Federal Reserve Press Releases",
        "url": "https://www.federalreserve.gov/feeds/press_all.xml",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "MarketWatch Top Stories",
        "url": "http://feeds.marketwatch.com/marketwatch/topstories/",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "WIRED",
        "url": "https://www.wired.com/feed/rss",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "CNET News",
        "url": "https://www.cnet.com/rss/news/",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "Engadget",
        "url": "https://www.engadget.com/rss.xml",
        "enabled": true,
        "category": "technology"
      },
      {
        "name": "VentureBeat",
        "url": "https://feeds.feedburner.com/venturebeat/SZYF",
        "enabled": true,
        "category": "technology"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "notifications": {
    "telegram": {
      "enabled": true,
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "chat_id_env": "TELEGRAM_CHAT_ID",
      "disable_notification": false
    }
  }
}
